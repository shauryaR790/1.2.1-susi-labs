# Copy to .env for local `vercel dev` only — never commit .env
# On production, set these in Vercel → Project → Settings → Environment Variables

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

SUSI_SUPABASE_URL=https://your-project.supabase.co
SUSI_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

RESEND_API_KEY=re_your_resend_key
ADMIN_EMAIL=you@example.com
RESEND_FROM=SUSI LABS <onboarding@resend.dev>

UPI_VPA=yourvpa@bank
UPI_PAYEE_NAME=SUSI LABS
